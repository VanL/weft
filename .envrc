PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

export UV_PROJECT_ENVIRONMENT="$PROJECT_ROOT/.venv"
export PATH="$PROJECT_ROOT/bin:$PATH"

if false; then
SIMPLEBROKER_DEV_ROOT="$PROJECT_ROOT/../simplebroker"
  if [ -d "$SIMPLEBROKER_DEV_ROOT/simplebroker" ]; then
    case ":${PYTHONPATH:-}:" in
      *":$SIMPLEBROKER_DEV_ROOT:"*) ;;
      *)
        export PYTHONPATH="$SIMPLEBROKER_DEV_ROOT${PYTHONPATH:+:$PYTHONPATH}"
        ;;
    esac
  fi
fi

if [ -f "$UV_PROJECT_ENVIRONMENT/bin/activate" ]; then
  . "$UV_PROJECT_ENVIRONMENT/bin/activate"
fi

